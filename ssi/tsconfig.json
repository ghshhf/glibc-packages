{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["core/src/**/*.ts", "bus/src/**/*.ts", "browser/src/**/*.ts", "packager/src/**/*.ts", "demo/**/*.ts", "ai/src/**/*.ts", "ui/src/**/*.ts", "db/src/**/*.ts", "hal/src/**/*.ts", "sec/src/**/*.ts", "fs/src/**/*.ts", "net/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
