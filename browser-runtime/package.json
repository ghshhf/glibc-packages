{
  "name": "@glibc-packages/browser-runtime",
  "version": "1.0.0",
  "description": "glibc-packages browser/WebAssembly runtime. Loads and runs WASM-compiled C/C++ libraries in browsers, Node.js, and Web Workers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "node dist/test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "emscripten",
    "browser",
    "glibc-packages",
    "virtual-fs",
    "cross-platform"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghshhf/glibc-packages.git",
    "directory": "browser-runtime"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "browser": {
    "./dist/index.js": "./dist/index.browser.js",
    "./dist/virtual-fs.js": "./dist/virtual-fs.browser.js",
    "./dist/networking.js": "./dist/networking.browser.js"
  },
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "node": "./dist/index.js",
      "worker": "./dist/index.worker.js",
      "default": "./dist/index.js"
    },
    "./wasm-loader": {
      "browser": "./dist/wasm-loader.browser.js",
      "node": "./dist/wasm-loader.js",
      "default": "./dist/wasm-loader.js"
    },
    "./virtual-fs": {
      "browser": "./dist/virtual-fs.browser.js",
      "node": "./dist/virtual-fs.js",
      "default": "./dist/virtual-fs.js"
    },
    "./networking": {
      "browser": "./dist/networking.browser.js",
      "node": "./dist/networking.js",
      "default": "./dist/networking.js"
    },
    "./threading": "./dist/threading.js"
  }
}
