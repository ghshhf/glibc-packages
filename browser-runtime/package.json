{
  "name": "@skynet/browser-runtime",
  "version": "1.0.0",
  "description": "SkyNet SSI-KRN Runtime Kernel: loads and runs .swbn components in browser/Node.js/Worker environments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "build:all": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "emscripten",
    "browser",
    "skynet",
    "virtual-fs",
    "cross-platform"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghshhf/glibc-packages.git",
    "directory": "browser-runtime"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./wasm-loader": "./dist/wasm-loader.js",
    "./virtual-fs": "./dist/virtual-fs.js",
    "./networking": "./dist/networking.js",
    "./threading": "./dist/threading.js"
  }
}
