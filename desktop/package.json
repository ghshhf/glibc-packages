{
  "name": "skynet-desktop",
  "version": "1.0.0",
  "description": "SkyNet SSI Runtime Desktop Dashboard — system status, component management, real-time logs",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "node build-electron.js",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "org.ai-tp.skynet",
    "productName": "SkyNet SSI Runtime",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "src/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  }
}
